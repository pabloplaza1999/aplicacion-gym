# ─────────────────────────────────────────────
# Gym Management System — Variables de entorno
# ─────────────────────────────────────────────
# Copiar este archivo a .env y ajustar los valores.
# .env NUNCA debe subirse al repositorio.

# ── Proyecto ──────────────────────────────────
PROJECT_NAME="Gym Management System"
DEBUG=false

# ── Base de datos ─────────────────────────────
# Docker: ruta absoluta al volumen montado en /app/data/
DATABASE_URL=sqlite:////app/data/gym.db
# Desarrollo local sin Docker (comentar la línea de arriba y usar esta):
# DATABASE_URL=sqlite:///./gym.db

# ── CORS ──────────────────────────────────────
# Orígenes permitidos para el backend.
# Docker local: frontend corre en :80
# Producción: reemplazar con el dominio real del frontend
CORS_ORIGINS=["http://localhost", "http://localhost:80"]

# ── Frontend (Vite — build time) ───────────────
# URL del backend que el NAVEGADOR usará para llamar a la API.
# Esta variable se embebe en el build estático al ejecutar docker compose up.
# Cambiarla ANTES de levantar el sistema; no tiene efecto en caliente.
#
# Solo el origen del servidor — SIN /api al final (el código lo agrega automáticamente).
# Docker local:
VITE_API_URL=http://localhost:8000
# Servidor/producción (ejemplo):
# VITE_API_URL=http://mi-servidor.com:8000
#
# Desarrollo local sin Docker: dejar vacío o comentado.
# El proxy de Vite (:5173 → :8000) tomará el control automáticamente.
# VITE_API_URL=
