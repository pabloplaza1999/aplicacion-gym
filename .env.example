# ─────────────────────────────────────────────
# Gym Platform — Variables de entorno
# ─────────────────────────────────────────────
# Copiar este archivo a .env y ajustar los valores.
# .env NUNCA debe subirse al repositorio.

# ── Proyecto ──────────────────────────────────
PROJECT_NAME="Gym Management System"
# SEC-011: producción DEBE correr con DEBUG=false (valor por defecto seguro).
# Solo el entorno de desarrollo activa DEBUG=true explícitamente.
DEBUG=false

# ── Seguridad — SECRET_KEY (SEC-009) ──────────
# Clave Fernet que cifra la contraseña SMTP en la BD.
# OBLIGATORIA en producción (DEBUG=false): si falta, el sistema NO arranca.
# Debe ser ÚNICA por instalación — NUNCA reutilizar la misma clave entre los
# distintos despliegues/gimnasios.
# Generar una con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ── Exposición de red — BIND_ADDR (SEC-005) ───
# Interfaz del host donde se publican los puertos (frontend :80 y backend :8000).
# Default seguro = 127.0.0.1 → el sistema solo es accesible desde la propia PC
# (escenario Local de una sola PC).
# Gimnasio multi-dispositivo en LAN: definir la IP LAN de la PC (ej. 192.168.1.50)
# o 0.0.0.0, y ajustar VITE_API_URL en consecuencia.
BIND_ADDR=127.0.0.1

# ── Base de datos ─────────────────────────────
# Docker: ruta absoluta al volumen montado en /app/data/
DATABASE_URL=sqlite:////app/data/gym.db
# Desarrollo local sin Docker (comentar la línea de arriba y usar esta):
# DATABASE_URL=sqlite:///./gym.db

# ── Autenticación JWT — F2 (jwt_secret_key) ───
# Clave para firmar los tokens JWT de sesión del operador.
# OBLIGATORIA en producción (DEBUG=false): si falta o usa el valor dev, el sistema NO arranca.
# Debe ser ÚNICA por instalación — NUNCA reutilizar entre gimnasios.
# Generar una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
# Tiempo de expiración del token en horas (default: 8)
# JWT_EXPIRE_HOURS=8

# ── Primer acceso admin — F2 (admin_initial_password) ─
# Contraseña usada SOLO en dos momentos:
#   1. Seed inicial del usuario admin (primer arranque sin DB).
#   2. Reset manual de contraseña via scripts/reset_admin.py.
# NO afecta la contraseña activa una vez el operador la haya cambiado en la UI.
ADMIN_INITIAL_PASSWORD=

# ── Super Admin — F4-C (super_admin_password) ─────────
# Contraseña del usuario super_admin (ISV / proveedor de la plataforma).
# Si está vacía, el usuario super_admin NO se crea. Configura solo en instalaciones
# donde se use el panel de licenciamiento (super_admin no es el operador del gimnasio).
# Reset manual: python scripts/reset_super_admin.py
# DEBE ser diferente de ADMIN_INITIAL_PASSWORD.
SUPER_ADMIN_PASSWORD=

# ── Identidad del gimnasio — F4-C (seed inicial) ──────
# Usadas SOLO en la primera inicialización de la BD (seed de gyms + gym_licenses).
# No tienen efecto si la tabla gyms ya tiene datos.
# GYM_NAME="Rhinopower"
# GYM_PLAN=professional      # starter / professional / premium

# ── CORS ──────────────────────────────────────
# Orígenes permitidos para el backend.
# Docker local: frontend corre en :80
# Producción: reemplazar con el dominio real del frontend
CORS_ORIGINS=["http://localhost", "http://localhost:80"]

# ── Feature flags — Módulos Premium ───────────
# Usados SOLO durante el seed inicial (_migrate_to_licensing_system).
# Después del primer arranque, la tabla gym_modules es la fuente de verdad.
# El Super Admin gestiona módulos desde la UI — no hace falta editar estas líneas.
#
# MODULE_NOTIFICATIONS=true    # P-01 Comunicación Automatizada
# MODULE_BODY_TRACKING=true    # P-07 Seguimiento Corporal
# MODULE_STORE=true            # Tienda

# ── Frontend (Vite — build time) ───────────────
# URL del backend que el NAVEGADOR usará para llamar a la API.
# Esta variable se embebe en el build estático al ejecutar docker compose up.
# Cambiarla ANTES de levantar el sistema; no tiene efecto en caliente.
#
# Solo el origen del servidor — SIN /api al final (el código lo agrega automáticamente).
# Docker local (PC única):
VITE_API_URL=http://localhost:8000
# Multi-dispositivo LAN (debe coincidir con BIND_ADDR = IP LAN de la PC):
# VITE_API_URL=http://192.168.1.50:8000
#
# Desarrollo local sin Docker: dejar vacío o comentado.
# El proxy de Vite (:5173 → :8000) tomará el control automáticamente.
# VITE_API_URL=
