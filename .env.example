# ─────────────────────────────────────────────
# Gym Management System — Variables de entorno
# ─────────────────────────────────────────────
# Copiar este archivo a .env y ajustar los valores.
# .env NUNCA debe subirse al repositorio.

# ── Proyecto ──────────────────────────────────
PROJECT_NAME="Gym Management System"
# SEC-011: producción DEBE correr con DEBUG=false (valor por defecto seguro).
# Solo el entorno de desarrollo activa DEBUG=true explícitamente.
DEBUG=false

# ── Seguridad — SECRET_KEY (SEC-009) ──────────
# Clave Fernet que cifra la contraseña SMTP en la BD.
# OBLIGATORIA en producción (DEBUG=false): si falta, el sistema NO arranca.
# Debe ser ÚNICA por instalación — NUNCA reutilizar la misma clave entre los
# distintos despliegues/gimnasios.
# Generar una con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ── Exposición de red — BIND_ADDR (SEC-005) ───
# Interfaz del host donde se publican los puertos (frontend :80 y backend :8000).
# Default seguro = 127.0.0.1 → el sistema solo es accesible desde la propia PC
# (escenario Local de una sola PC).
# Gimnasio multi-dispositivo en LAN: definir la IP LAN de la PC (ej. 192.168.1.50)
# o 0.0.0.0, y ajustar VITE_API_URL en consecuencia.
# ADVERTENCIA: exponer en LAN sin autenticación (pendiente F2) es un riesgo
# residual; hacerlo solo de forma consciente.
BIND_ADDR=127.0.0.1

# ── Base de datos ─────────────────────────────
# Docker: ruta absoluta al volumen montado en /app/data/
DATABASE_URL=sqlite:////app/data/gym.db
# Desarrollo local sin Docker (comentar la línea de arriba y usar esta):
# DATABASE_URL=sqlite:///./gym.db

# ── CORS ──────────────────────────────────────
# Orígenes permitidos para el backend.
# Docker local: frontend corre en :80
# Producción: reemplazar con el dominio real del frontend
CORS_ORIGINS=["http://localhost", "http://localhost:80"]

# ── Frontend (Vite — build time) ───────────────
# URL del backend que el NAVEGADOR usará para llamar a la API.
# Esta variable se embebe en el build estático al ejecutar docker compose up.
# Cambiarla ANTES de levantar el sistema; no tiene efecto en caliente.
#
# Solo el origen del servidor — SIN /api al final (el código lo agrega automáticamente).
# Docker local (PC única):
VITE_API_URL=http://localhost:8000
# Multi-dispositivo LAN (debe coincidir con BIND_ADDR = IP LAN de la PC):
# VITE_API_URL=http://192.168.1.50:8000
#
# Desarrollo local sin Docker: dejar vacío o comentado.
# El proxy de Vite (:5173 → :8000) tomará el control automáticamente.
# VITE_API_URL=
